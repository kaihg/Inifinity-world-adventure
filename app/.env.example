# LLM 後端（OpenAI 相容）。可指向 OpenAI、vLLM、Ollama(OpenAI 模式)、LM Studio 等。
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
MODEL=gpt-4o

# 伺服器
PORT=5173
# HOST=127.0.0.1
# DEBUG_MODE=false

# git 提交身分（每回合自動 commit world/ 用）
GIT_AUTHOR_NAME=Infinity World Engine
GIT_AUTHOR_EMAIL=engine@localhost

# world/ 目錄（相對於 repo 根；預設自動偵測）
# WORLD_DIR=../world

# 角色意圖 LLM（選填；缺省沿用主 LLM）
# CHARACTER_OPENAI_BASE_URL=http://localhost:11434/v1
# CHARACTER_MODEL=qwen2.5:3b

# Layer 2 fast-control 抽取 LLM（選填；缺省沿用主 LLM）
# 主敘事用大模型衝文筆，fast-control 可用小/快模型專心抽 now/主角/轉場等即時狀態
# CONTROL_OPENAI_BASE_URL=http://localhost:11434/v1
# CONTROL_MODEL=qwen2.5:7b

# Layer 3 reactive-lore-sync 抽取 LLM（選填；缺省依序退回 control、主 LLM）
# 不卡玩家可見的回合結束，負責 NPC/道具/場景/技能等可延後落地的 lore 欄位
# LORE_OPENAI_BASE_URL=http://localhost:11434/v1
# LORE_MODEL=qwen2.5:7b

# 語意檢索（recall，選填）：每回合用玩家輸入做語意搜尋，把相關片段注入 system prompt
# 索引存在本機 app/.recall-index/，是 derived cache（不進 git，可隨時刪除重建）
# 啟用後首次啟動會下載本地嵌入模型（Xenova/all-MiniLM-L6-v2）
RECALL_ENABLED=true
RECALL_INDEX_DIR=.recall-index
RECALL_TOP_K=5

# 短期停滯規則（規則式，本地嵌入相似度比較，選填，皆有預設值）
# NUDGE_WINDOW_SIZE=3
# NUDGE_SIMILARITY_THRESHOLD=0.92

# 長期節奏審閱（劇本大師，每 K 回合跑一次獨立 LLM，選填）
# PACING_REVIEW_INTERVAL=10
# PACING_OPENAI_BASE_URL=http://localhost:11434/v1
# PACING_MODEL=qwen2.5:7b

# LLM 呼叫耗時/token 用量 log（derived，不進 git，append-only JSON Lines；預設 app/.llm-usage.log）
# USAGE_LOG_PATH=.llm-usage.log

# 前端打字機速度：每字元顯示間隔毫秒數（越小越快；預設 25，即每秒約 40 字元）
# TYPEWRITER_INTERVAL_MS=25
