# LLM 後端（OpenAI 相容）。可指向 OpenAI、vLLM、Ollama(OpenAI 模式)、LM Studio 等。
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
MODEL=gpt-4o

# 伺服器
PORT=5173
# HOST=127.0.0.1
# DEBUG_MODE=false

# git 提交身分（每回合自動 commit world/ 用）
GIT_AUTHOR_NAME=Infinity World Engine
GIT_AUTHOR_EMAIL=engine@localhost

# 單次 /api/turn 最多自動推進幾個回合（避免失控燒 token）
AUTO_ADVANCE_MAX=4

# world/ 目錄（相對於 repo 根；預設自動偵測）
# WORLD_DIR=../world
