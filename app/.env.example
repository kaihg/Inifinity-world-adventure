# LLM 後端（OpenAI 相容）。可指向 OpenAI、vLLM、Ollama(OpenAI 模式)、LM Studio 等。
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
MODEL=gpt-4o

# 伺服器
PORT=5173
# HOST=127.0.0.1
# DEBUG_MODE=false

# git 提交身分（每回合自動 commit world/ 用）
GIT_AUTHOR_NAME=Infinity World Engine
GIT_AUTHOR_EMAIL=engine@localhost

# 單次 /api/turn 最多自動推進幾個回合（避免失控燒 token）
AUTO_ADVANCE_MAX=4

# world/ 目錄（相對於 repo 根；預設自動偵測）
# WORLD_DIR=../world

# 角色意圖 LLM（選填；缺省沿用主 LLM）
# CHARACTER_OPENAI_BASE_URL=http://localhost:11434/v1
# CHARACTER_MODEL=qwen2.5:3b

# 語意檢索（recall，選填）：每回合用玩家輸入做語意搜尋，把相關片段注入 system prompt
# 索引存在本機 app/.recall-index/，是 derived cache（不進 git，可隨時刪除重建）
# 啟用後首次啟動會下載本地嵌入模型（Xenova/all-MiniLM-L6-v2）
# RECALL_ENABLED=true
# RECALL_INDEX_DIR=.recall-index
# RECALL_TOP_K=5
