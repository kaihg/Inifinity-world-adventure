{
  "name": "infinity-world-adventure-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "無限世界冒險：劇情遊玩網頁引擎（可設定 OpenAI 相容後端）",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "start": "node dist/server/index.js",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:server": "tsc -p tsconfig.build.json",
    "build:web": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "reindex": "tsx src/recall/reindex-all.ts"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@huggingface/transformers": "^4.2.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "openai": "^4.67.3",
    "opencc-js": "^1.3.1",
    "pino": "^9.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-git": "^3.27.0",
    "vectra": "^0.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/opencc-js": "^1.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^10.0.3",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.3"
  }
}
